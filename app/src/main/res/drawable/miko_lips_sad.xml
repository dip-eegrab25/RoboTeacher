<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="100dp"
    android:height="40dp"
    android:viewportWidth="100"
    android:viewportHeight="40">
    
    <group android:name="lips_group"
           android:rotation="0"
           android:pivotX="50"
           android:pivotY="20">

        <group android:name="upper_lip">
        
        <!-- Upper Lip -->
        <path
              android:pathData="M 35 20 
              Q 42.5 9.5 50 12
              Q 57.5 9.5 65 20"
              android:fillColor="#c53030"
              android:strokeColor="#991b1b"
              android:strokeWidth="1"/>

        </group>

        <group android:name="lower_lip">
        
        <!-- Lower Lip -->
        <path
              android:pathData="M 35 20 
              Q 42.5 25.5 50 23
              Q 57.5 25.5 65 20"
              android:fillColor="#dc2626"
              android:strokeColor="#991b1b"
              android:strokeWidth="1"/>

        </group>
        
        <!-- Lip shine effect -->
        <path android:name="lip_shine"
              android:pathData="M 40,16 Q 50,11 60,16"
              android:strokeColor="#ffffff"
              android:strokeWidth="1"

              android:fillAlpha="0.3"/>
              
    </group>
</vector>