<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    
    <group android:name="lips_group"
           android:rotation="0"
           android:pivotX="100"
           android:pivotY="100"
        android:translateX="20"
        android:translateY="40">

        <group android:name="upper_lip">
        
        <!-- Upper Lip -->
        <path
              android:pathData="M 0 60
              Q 40 20 80 20
              Q 120 20 160 60"
              android:fillColor="#c53030"
              android:strokeColor="#991b1b"
              android:strokeWidth="1"/>

        </group>

        <group android:name="lower_lip">
        
        <!-- Lower Lip -->
        <path
              android:pathData="M 0 60
              Q 40 100 80 100
              Q 120 100 160 60"
              android:fillColor="#dc2626"
              android:strokeColor="#991b1b"
              android:strokeWidth="1"/>

        </group>
        
