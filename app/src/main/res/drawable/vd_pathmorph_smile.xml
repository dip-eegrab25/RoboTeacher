<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="300dp"
    android:height="300dp"
    android:viewportWidth="300"
    android:viewportHeight="300">

    <group
        android:translateX="0"
        android:translateY="150">

        <path
            android:name="smile_path"
            android:pathData="M 30,0 C 30,0 150,150 270,0"
            android:trimPathStart="0"
            android:trimPathEnd="1"
            android:strokeColor="#99fdfa"
            android:strokeWidth="10"/>

    </group>

    <group android:rotation="50"
        android:translateX="55"
        android:translateY="130"
        android:pivotX="0"
        android:pivotY="0">

        <path
            android:name="smile_path_left"
            android:pathData="M0,0 L 0,60"
            android:trimPathStart="0.2"
            android:trimPathEnd="0.8"
            android:strokeColor="#99fdfa"
            android:strokeWidth="5"/>

    </group>

    <group android:rotation="-50"
        android:translateX="245"
        android:translateY="130">

        <path
            android:name="smile_path_right"
            android:pathData="M0,0 L 0,60"
            android:trimPathStart="0.2"
            android:trimPathEnd="0.8"
            android:strokeColor="#99fdfa"
            android:strokeWidth="5"/>

    </group>
</vector>